# ─── Database ────────────────────────────────────────────────────────────────
# Development (SQLite via libSQL):
DATABASE_URL="file:./dev.db"

# Production — use Turso (hosted libSQL):
#   DATABASE_URL="libsql://<your-db>.turso.io?authToken=<your-token>"
# Or switch to PostgreSQL (requires changing prisma/schema.prisma provider):
#   DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# ─── Auth ─────────────────────────────────────────────────────────────────────
# REQUIRED in production — must be a strong random secret (32+ chars)
# Generate: openssl rand -base64 32
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND

# Public URL of the app (used for redirects and absolute URLs in emails)
NEXTAUTH_URL=https://yourdomain.com

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Get your key at https://resend.com — without this, emails are logged to console only
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# From address for transactional emails (must be a verified Resend domain)
RESEND_FROM=noreply@yourdomain.com

# ─── Cron Security ────────────────────────────────────────────────────────────
# Secret token for the investment maturity cron endpoint (/api/cron/process-investments)
# Set this in your cron provider (Vercel Cron, GitHub Actions, etc.)
# If unset, the endpoint is UNPROTECTED — always set in production
# Generate: openssl rand -hex 32
CRON_SECRET=CHANGE_ME_IN_PRODUCTION_USE_OPENSSL_RAND

# ─── Deployment ───────────────────────────────────────────────────────────────
NODE_ENV=production
